{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "qred",
  "compatibility_date": "2026-06-22",
  "main": "./worker/index.js",
  "build": {
    "command": "npm run build:worker"
  },
  "assets": {
    "directory": "./build",
    "binding": "ASSETS",
    "run_worker_first": ["/api/*"],
    "not_found_handling": "single-page-application"
  },
  "vars": {
    "QRED_API_ORIGIN": ""
  }
}
